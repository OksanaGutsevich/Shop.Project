{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2018",
    "rootDir": ".",
    "lib": ["es2018"],
    "skipLibCheck": true,
    "types": ["node", "express-session"],
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "useUnknownInCatchVariables": false,
    "verbatimModuleSyntax": false,
    "paths": {
      "@Shared/*": ["./Shared/*"]
    }
  },
  "include": [
    "**/*.ts",
    "express.d.ts",
    "src/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
