{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2018",
    "lib": ["es2018"],
    "skipLibCheck": true,
    "types": ["node"],
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "useUnknownInCatchVariables": false,
    "verbatimModuleSyntax": false,
    "paths": {
      "@Shared/*": ["../Shared/*"]
    }
  },
  "exclude": [
    "node_modules"
  ]
}

