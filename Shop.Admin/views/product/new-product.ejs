<h1>Create New Product</h1>

<!-- Обычная отправка формы -->
<form action="/admin/new-product" method="POST">
  <div class="field">
    <label for="title">Title:</label>
    <input id="title" type="text" name="title" required />
  </div>

  <div class="field">
    <label for="description">Description:</label>
    <textarea id="description" rows="3" name="description"></textarea>
  </div>

  <div class="field">
    <label for="price">Price:</label>
    <input id="price" type="number" name="price" step="0.01" required />
  </div>

  <div class="field">
    <label>Images URLs (one per line or comma‑separated):</label>
    <textarea
      id="images"
      rows="4"
      name="images"
      placeholder="https://example.com/img1.jpg&#10;https://example.com/img2.jpg"
    ></textarea>
  </div>

  <button type="submit">Create Product</button>
</form>
