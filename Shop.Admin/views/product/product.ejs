<h1><%= item.title %></h1>

<form action="<%= `save/${item.id}` %>" method="post" class="product-edit-form">
  <div class="product-edit-fields">
    <div class="field">
      <label for="item-title">Title:</label>
      <input
        id="item-title"
        type="text"
        name="title"
        value="<%= item.title %>"
      />
    </div>

    <div class="field">
      <label for="item-description">Description:</label>
<textarea id="item-description" rows="3" name="description"><%= item.description %></textarea>

    </div>

    <div class="field">
      <label for="item-price">Price:</label>
      <input
        id="item-price"
        type="text"
        name="price"
        value="<%= item.price %>"
      />
    </div>

    <div class="field">
      <label for="item-new-images"
        >New images URLs (use line break or a comma):</label
      >
      <textarea id="item-new-images" rows="3" name="newImages"></textarea>
    </div>
  </div>

<% if (item.comments?.length) { %>
  <h2>Comments</h2>
  <div class="product-edit-comments">
    <% item.comments.forEach(function(comment, index) { %>
      <%- include('product-comments', { comment: comment, index: index }) %>
    <% }); %>
  </div>
<% } %>


          <% if (item.images?.length) { %>
        <h2>Images</h2>
        <div class="product-edit-images">
            <% item.images.forEach(function(image) { %>
                <%- include('product-image', { image: image }) %>
                    <% }); %>
        </div>
        <% } %>

        <div class="product-edit-footer">
        <button type="submit">Save changes</button>
        <a href="<%= `remove-product/${item.id}` %>">Delete product</a>
    </div> 
       

</form>

 <!-- ДЛЯ ПОХОЖИХ ТОВАРОВ -->
<% if (typeof similarProducts !== 'undefined' && similarProducts.length > 0) { %>
  <section style="margin-top: 3rem; padding: 1rem; border-top: 2px solid #00b1ffff;">
    <h2>Similar Products</h2>

    <!-- Путь исправлен на /admin -->
    <form
      action="/admin/<%= item.id %>/similar/remove"
      method="POST"
      onsubmit="return confirm('Вы уверены, что хотите удалить выбранные связи?');"
      style="display: flex; flex-direction: column; gap: 1rem;"
    >
      <div class="similar-products-list" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1rem;">
        <% similarProducts.forEach(function(prod) { %>
          <div class="product-similar-item" style="border: 1px solid #ddd; padding: 0.8rem; border-radius: 4px;">
            <div style="margin-bottom: 0.5rem;">
              <strong><%= prod.title %></strong>
              <span style="float: right; color: #555; font-size: 0.9em;">$<%= prod.price %></span>
            </div>
            <% if (prod.description) { %>
              <div style="font-size: 0.85em; color: #666; margin-bottom: 0.8rem;">
                <%= prod.description %>
              </div>
            <% } %>

            <!-- Чекбокс -->
            <div style="display: flex; align-items: center; gap: 8px;">
              <label for="chk-<%= prod.id %>" style="cursor: pointer; margin: 0;">Mark to remove</label>
              <input
                type="checkbox"
                id="chk-<%= prod.id %>"
                value="<%= prod.id %>"
                name="ids[]"
                style="cursor: pointer;"
              />
            </div>
          </div>
        <% }); %>
      </div>

      <button type="submit" style="background: #d9534f; color: white; border: none; padding: 8px 16px; cursor: pointer; align-self: flex-start;">
        Remove selected links
      </button>
    </form>
  </section>
<% } else if (typeof similarProducts !== 'undefined') { %>
  <p style="margin-top: 1.5rem; color: #777;">Нет похожих товаров.</p>
<% } %>

<!-- БЛОК: ДОБАВЛЕНИЕ НОВЫХ ПОХОЖИХ ТОВАРОВ ИЗ ОБЩЕГО СПИСКА (БЕЗ УЧЕТА САМОГО ТОВАРА И ПОХОЖИХ) -->
<% if (typeof candidates !== 'undefined' && candidates.length > 0) { %>
  <section style="margin-top: 3rem; padding: 1rem; border-top: 2px solid #333; border-color:#00b1ffff;">
    <h2>Products list</h2>
    
    <!-- Форма отправляет POST на эндпоинт добавления -->
    <form
      action="/admin/<%= item.id %>/similar/add"
      method="POST"
      onsubmit="return confirm('Вы уверены, что хотите добавить выбранные товары в похожие?');"
      style="display: flex; flex-direction: column; gap: 1rem;"
    >
      <div class="candidates-list" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; max-height: 400px; overflow-y: auto; border: 1px solid #eee; padding: 1rem;">
        
        <% candidates.forEach(function(prod) { %>
          <div class="candidate-item" style="border: 1px solid #ddd; padding: 0.8rem; border-radius: 4px; display: flex; flex-direction: column;">
            <strong><%= prod.title %></strong>
            <span style="font-size: 0.9em; color: #777;">$<%= prod.price %></span>
            
            <div style="margin-top: 0.5rem; display: flex; align-items: center; gap: 8px;">
              <label for="cand-<%= prod.id %>" style="cursor: pointer; margin: 0; font-size: 0.9em;">Select</label>
              <input
                type="checkbox"
                id="cand-<%= prod.id %>"
                value="<%= prod.id %>"
                name="ids[]"
                style="cursor: pointer;"
              />
            </div>
          </div>
        <% }); %>
      </div>

      <button type="submit" style="background: #27ae60; color: white; border: none; padding: 10px 20px; cursor: pointer; align-self: flex-start;">
        Add Selected to Similar
      </button>
    </form>
  </section>
<% } else if (typeof candidates !== 'undefined') { %>
  <p style="margin-top: 1.5rem; color: #777;">Нет товаров для добавления (все остальные уже являются похожими или это единственный товар).</p>
<% } %>
